---
---
<!-- TWProbe Buttons (Global Action Hub) -->
<div class="tw-share-container twp-fab-group">
    
    <!-- 沉浸式閱讀模式 -->
    <button class="tw-share-toggler twp-reading-fab" id="twpThemeToggleBtn" aria-label="切換閱讀模式" title="閱讀模式">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
    </button>

    <!-- 回原站按鈕 (Blue House) 取代 Radar -->
    <a href="https://twprobe.com" class="tw-share-toggler" aria-label="回主站" title="首頁">
        <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" scale="0.8"><path d="M16 2L2 12h3v14h7v-8h8v8h7V12h3L16 2z"/></svg>
    </a>

    <!-- 分享按鈕展開器 -->
    <div class="tw-share-group" id="twp-share-wrapper">
        <button class="tw-share-toggler twp-share-action share-deep-blue" aria-label="Share options">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
        </button>
        <div class="tw-share-menu">
            <button class="tw-share-btn btn-line twp-social-share" data-platform="line" aria-label="Share on Line">
                <svg class="twp-share-svg" viewBox="0 0 24 24"><path d="M24 10.3c0-5.7-5.4-10.3-12-10.3S0 4.6 0 10.3c0 5.1 4.3 9.3 10.2 10.2.4.1.9.3.7 1.2l-.3 1.5c0 0-.2 1.1.9.6 5.6-3.3 9.2-7.2 9.2-7.2 3.3-1.7 3.3-6.2 3.3-6.2z"/></svg>
            </button>
            <button class="tw-share-btn btn-fb twp-social-share" data-platform="fb" aria-label="Share on Facebook">
                <svg class="twp-share-svg" viewBox="0 0 24 24"><path d="M24 12c0-6.6-5.4-12-12-12S0 5.4 0 12c0 6 4.4 11 10.1 11.9v-8.4H7v-3.5h3.1V9.4c0-3 1.8-4.7 4.5-4.7 1.3 0 2.7.2 2.7.2v3h-1.5c-1.5 0-2 .9-2 1.9v2.3h3.3l-.5 3.5h-2.8v8.4C19.6 23 24 18 24 12z"/></svg>
            </button>
            <button class="tw-share-btn btn-messenger twp-social-share" data-platform="messenger" aria-label="Share on Messenger">
                <svg class="twp-share-svg" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5 0 11.1c0 3.5 1.7 6.6 4.5 8.7V24l4.1-2.2c1.1.3 2.2.5 3.4.5 6.6 0 12-5 12-11.1S18.6 0 12 0zm1.2 15l-3.1-3.3-6 3.3 6.6-7 3.3 3.3 5.6-3.3-6.4 7z"/></svg>
            </button>
            <button class="tw-share-btn btn-threads twp-social-share" data-platform="threads" aria-label="Share on Threads">
                <svg class="twp-share-svg" viewBox="0 0 24 24"><path d="M17.8 22.8a12.8 12.8 0 0 0 2.5-1.2l-1.4-2.2a10.6 10.6 0 0 1-1.9.9c-3.2.9-6.2-.2-7.6-3.4-.4-1-.6-2.2-.6-3.8v-1.1c0-3.7 2.6-6.5 5.8-6.5 3.1 0 5.1 2.1 5.1 5.1v3c0 2.1-1.5 2.4-2 2.4-.5 0-1.5-.2-1.5-2V8.9a2.9 2.9 0 0 0-2.3-1.2c-1.7 0-3 1.4-3 3.4 0 2 1.3 3.4 3 3.4 1.2 0 2.1-.6 2.7-1.4.4 1.5 1.9 2.3 3.4 2.3 1.8 0 3.8-1.3 3.8-4.9V7.5C24 3 19.5 0 13.1 0 6.3 0 1.3 4.5 1.3 11.8c0 7.4 5.2 12 12.3 12 1.5 0 2.9-.3 4.1-.9l-1-2.3-1 .3ZM13.1 13.5c-1.4 0-2-1-2-2.2 0-1.3.7-2.3 2-2.3.9 0 1.6.7 1.6 2.3 0 1.6-.7 2.2-1.6 2.2Z"/></svg>
            </button>
            <button class="tw-share-btn btn-copy twp-copy-action-btn" aria-label="Copy Link">
                <svg class="default-icon twp-share-svg" viewBox="0 0 24 24"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
                <svg class="success-icon twp-share-svg" viewBox="0 0 24 24" style="display:none;"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>
            </button>
    <!-- 回原站按鈕 (Blue House) 取代 Radar -->
    <a href="https://twprobe.com" class="tw-share-toggler" aria-label="回主站" title="首頁">
        <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" scale="0.8"><path d="M16 2L2 12h3v14h7v-8h8v8h7V12h3L16 2z"/></svg>
    </a>

</div>

<!-- 毛玻璃 返回按鈕 (左上角) -->
<a href="#" id="twp-smart-back-btn" class="twp-glass-btn twp-back-btn" aria-label="返回上一頁">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
    <span>返回</span>
</a>

<!-- 毛玻璃 回到頁首 (右下角) -->
<button id="twp-scroll-top-btn" class="twp-glass-btn twp-top-btn" aria-label="回到頁首">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"></polyline></svg>
</button>

<style is:global>
/* TWProbe Left Bottom Flow UI */
.tw-share-container {
    position: fixed; bottom: 25px; left: 25px;
    z-index: 9999998;
    display: flex; flex-direction: column-reverse; gap: 10px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.tw-share-toggler {
    width: 44px !important; height: 38px !important; min-width: 44px !important; padding: 0 !important;
    background: #1E90FF; border: none; border-radius: 6px !important; color: #ffffff; text-decoration: none !important;
    display: flex !important; align-items: center !important; justify-content: center !important; cursor: pointer;
    box-shadow: 0 4px 15px rgba(30, 144, 255, 0.2); transition: all 0.2s ease;
    position: relative; z-index: 2;
}
.tw-share-toggler:hover { transform: translateY(-2px); background: #0073E6; box-shadow: 0 6px 20px rgba(30, 144, 255, 0.3); color: white; }
.tw-share-toggler svg { width: 18px; height: 18px; stroke: white; stroke-width: 2.5; fill: none; margin: 0 auto; display: block; transition: transform 0.3s; }

.tw-share-group { position: relative; display: flex; align-items: center; }

/* 深色調分享按鈕 */
.tw-share-toggler.share-deep-blue { background: #1E3A8A; box-shadow: 0 4px 15px rgba(30, 58, 138, 0.4); }
.tw-share-toggler.share-deep-blue:hover { background: #172554; box-shadow: 0 6px 20px rgba(30, 58, 138, 0.5); }
.tw-share-group.expanded .tw-share-toggler.share-deep-blue { background: #0F172A; box-shadow: 0 4px 15px rgba(15, 23, 42, 0.5); }
.tw-share-group.expanded .tw-share-toggler svg { transform: rotate(90deg); }

.tw-share-menu {
    position: absolute; bottom: 0; left: 52px; transform: translateX(15px) scale(0.9);
    display: flex; flex-direction: row; gap: 8px;
    background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    padding: 5px 8px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.6);
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    opacity: 0; visibility: hidden; z-index: 1; transition: all 0.25s cubic-bezier(0.18, 0.89, 0.32, 1.28);
    pointer-events: none; align-items: center;
}
.tw-share-group.expanded .tw-share-menu {
    transform: translateX(0) scale(1);
    opacity: 1; visibility: visible; pointer-events: auto;
}

.tw-share-btn {
    width: 32px; height: 32px; border-radius: 50%; display: flex; justify-content: center; align-items: center;
    background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.05); transition: all 0.2s;
    text-decoration: none; border: none; cursor: pointer; flex-shrink: 0;
}
.tw-share-btn:hover { transform: translateY(-2px) scale(1.1); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
.tw-share-svg { width: 14px; height: 14px; }

.btn-line .tw-share-svg { fill: #06C755; stroke: none; }
.btn-fb .tw-share-svg { fill: #1877F2; stroke: none; }
.btn-messenger .tw-share-svg { fill: #00B2FF; stroke: none;}
.btn-threads .tw-share-svg { fill: #000000; stroke: none;}
.btn-copy .default-icon { fill: #64748B; stroke: none;}
.btn-copy.copied .default-icon { display: none !important; }
.btn-copy.copied .success-icon { display: block !important; fill: #10B981; stroke: none;}

@media (max-width: 768px) {
    .tw-share-container { bottom: 20px; left: 15px; gap: 8px; }
    .tw-share-toggler { width: 38px !important; height: 34px !important; min-width: 38px !important; border-radius: 5px !important; }
    .tw-share-toggler svg { width: 16px; height: 16px; stroke-width: 2.2; }
    .tw-share-menu { left: 45px; transform: translateX(10px) scale(0.9); }
}

/* 毛玻璃全域按鈕設計 */
.twp-glass-btn {
    position: fixed; z-index: 9999995;
    background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.6); box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    color: #334155; text-decoration: none; cursor: pointer;
    transition: all 0.25s cubic-bezier(0.18, 0.89, 0.32, 1.28);
    display: flex; align-items: center; justify-content: center;
}
.twp-glass-btn:hover {
    background: rgba(255, 255, 255, 0.7); box-shadow: 0 6px 24px rgba(0,0,0,0.1); transform: translateY(-2px);
}
.twp-back-btn {
    top: 25px; left: 25px; font-weight: bold; font-size: 13px; gap: 4px;
    padding: 8px 14px 8px 10px; border-radius: 20px;
}
.twp-back-btn svg { width: 16px; height: 16px; }
.twp-top-btn {
    bottom: 25px; right: 25px; width: 44px; height: 44px; border-radius: 50%;
    opacity: 0; pointer-events: none; transform: translateY(15px);
}
.twp-top-btn.visible {
    opacity: 1; pointer-events: auto; transform: translateY(0);
}
.twp-top-btn svg { width: 22px; height: 22px; }

@media (max-width: 768px) {
    .twp-back-btn { top: 15px; left: 15px; padding: 6px 10px; font-size: 12px; }
    .twp-top-btn { bottom: 20px; right: 15px; width: 38px; height: 38px; }
}

/* 暗黑模式對應 (包含毛玻璃按鈕) */
html.twp-dark-mode .twp-glass-btn {
    background: rgba(15, 23, 42, 0.4); border-color: rgba(255, 255, 255, 0.1); color: #E2E8F0;
}
html.twp-dark-mode .twp-glass-btn:hover {
    background: rgba(15, 23, 42, 0.7); box-shadow: 0 4px 15px rgba(0,0,0,0.5);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    
    // 暗黑模式邏輯 (Astro)
    const btn = document.getElementById('twpThemeToggleBtn');
    if (localStorage.getItem('twp-theme') === 'dark' || localStorage.getItem('theme') === 'dark') {
        document.documentElement.classList.add('twp-dark-mode', 'dark'); 
    }
    btn?.addEventListener('click', () => {
        document.documentElement.classList.toggle('twp-dark-mode');
        document.documentElement.classList.toggle('dark');
        let isDark = document.documentElement.classList.contains('twp-dark-mode');
        localStorage.setItem('twp-theme', isDark ? 'dark' : 'light');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // 分享選單邏輯
    document.body.addEventListener('click', function(e) {
        const target = e.target;
        if (!(target instanceof Element)) return;
        
        let targetToggle = target.closest('.twp-share-action');
        if (targetToggle) {
            e.preventDefault();
            let targetUrl = window.location.href;
            if (navigator.share && /Mobi|Android/i.test(navigator.userAgent)) {
                navigator.share({
                    title: document.title,
                    url: targetUrl
                }).catch(function() {});
                return;
            }

            let container = targetToggle.closest('.tw-share-group');
            if (container) container.classList.toggle('expanded');
            return;
        }
        
        if (!target.closest('.tw-share-group') && !target.closest('.tw-share-menu')) {
            document.querySelectorAll('.tw-share-group.expanded').forEach(function(el) {
                el.classList.remove('expanded');
            });
        }
        
        // 分享按鈕生成連結邏輯
        let socialBtn = target.closest('.twp-social-share');
        if (socialBtn) {
            let platform = socialBtn.getAttribute('data-platform');
            let url = encodeURIComponent(window.location.href);
            let title = encodeURIComponent(document.title + " " + window.location.href);
            let fb_app_id = '521270401588372';
            
            let finalUrl = '';
            if (platform === 'line') finalUrl = `https://social-plugins.line.me/lineit/share?url=${url}`;
            if (platform === 'fb') finalUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
            if (platform === 'messenger') finalUrl = `https://www.facebook.com/dialog/send?app_id=${fb_app_id}&link=${url}&redirect_uri=${url}`;
            if (platform === 'threads') finalUrl = `https://www.threads.net/intent/post?text=${title}`;
            
            if (finalUrl) window.open(finalUrl, '_blank');
            return;
        }

        // 複製連結邏輯
        let copyBtn = target.closest('.twp-copy-action-btn');
        if (copyBtn) {
            e.preventDefault();
            let url = window.location.href;
            if (navigator && navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(url).then(function() {
                    copyBtn.classList.add('copied');
                    setTimeout(function() {
                        copyBtn.classList.remove('copied');
                    }, 2000);
                }).catch(function(err) {});
            }
            return;
        }

        // Smart Back 按鈕
        let backBtn = target.closest('#twp-smart-back-btn');
        if (backBtn) {
            e.preventDefault();
            history.length > 2 ? history.back() : window.location.href = 'https://twprobe.com';
            return;
        }

        // 回到頁首按鈕
        let topBtn = target.closest('#twp-scroll-top-btn');
        if (topBtn) {
            e.preventDefault();
            window.scrollTo({ top: 0, left: 0, behavior: 'smooth' });
            return;
        }
    });

    // 監聽滾動事件顯示回到頁首按鈕
    window.addEventListener('scroll', function() {
        let topBtn = document.getElementById('twp-scroll-top-btn');
        if (topBtn) {
            if (window.scrollY > 300) {
                topBtn.classList.add('visible');
            } else {
                topBtn.classList.remove('visible');
            }
        }
    });

});
</script>
