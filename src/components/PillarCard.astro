---
interface Props {
  pillar: any;
}
const { pillar } = Astro.props;
---
<a
  href={pillar.url}
  class="group relative bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-t-4 border-t-blue-600 dark:border-t-twprobe-blue border border-slate-200 dark:border-slate-800/80 p-5 md:p-6 lg:p-8 rounded-b-xl shadow-sm dark:shadow-none hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] dark:hover:shadow-[0_0_20px_rgba(37,99,235,0.15)] hover:-translate-y-1 hover:border-blue-400 dark:hover:border-slate-600 transition-all duration-300 flex flex-col h-full flex-1 overflow-hidden"
>
  <span class="font-mono text-xs font-bold text-blue-600 dark:text-twprobe-blue tracking-widest mb-3 block">
    {pillar.frontmatter.docId}
  </span>
  <h2 class="text-xl md:text-2xl lg:text-3xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight mb-4 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
    {pillar.frontmatter.title}
  </h2>
  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-4 mb-6 relative z-10">
    {pillar.frontmatter.abstract}
  </p>
  <div class="mt-auto font-mono text-[10px] font-bold text-slate-400 dark:text-slate-500 flex items-center gap-2 group-hover:text-blue-600 dark:group-hover:text-twprobe-blue transition-colors">
    ACCESS PILLAR{" "}
    <span class="group-hover:translate-x-1 transition-transform">
      →
    </span>
  </div>
</a>
