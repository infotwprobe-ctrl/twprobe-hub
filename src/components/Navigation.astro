---
import ThemeToggle from './ThemeToggle.astro';
---
<nav class="sticky top-0 z-50 border-b border-slate-200 dark:border-slate-800/80 bg-white/90 dark:bg-slate-950/80 backdrop-blur-md px-3 md:px-6 lg:pl-[60px] py-3 lg:py-4 min-h-[60px] lg:min-h-[72px] flex flex-col justify-center w-full shadow-sm relative">
  <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-3 lg:gap-0">
    
    <!-- 行動版第一排：置中的 Logo -->
    <div class="flex lg:hidden justify-center w-full pb-2 border-b border-slate-100 dark:border-slate-800/50">
        <a class="flex items-center gap-2 group no-underline shrink-0" href="/">
          <svg class="h-6 w-6 rounded-[4px] shadow-sm transition-transform group-hover:scale-105" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
              <rect width="32" height="32" fill="#f8fafc" rx="4" class="dark:fill-slate-800" />
              <g transform="translate(4, 4)">
                  <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="#2563EB" class="dark:fill-twprobe-blue" />
              </g>
          </svg>
          <span class="font-bold text-slate-800 dark:text-slate-100 text-[1rem] tracking-wide whitespace-nowrap">TWProbe 深層架構中樞</span>
        </a>
    </div>

    <!-- 行動版第二排統整區塊 / 桌機版主導航列 -->
    <div class="flex flex-nowrap items-center justify-between w-full z-20 gap-2 lg:gap-0">
       
       <!-- 區域 1: 桌機左側 (Logo + 分類) / 行動版左側 (漢堡) -->
       <div class="flex items-center">
         <!-- 漢堡按鈕 (僅行動版顯示) -->
         <button id="mobile-menu-btn" class="lg:hidden p-1.5 -ml-1 text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800/80 rounded-md focus:outline-none transition-colors shrink-0" aria-label="Toggle menu">
            <svg class="w-[1.4rem] h-[1.4rem]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
         </button>

         <!-- 桌機版 Logo (僅桌機版顯示) -->
         <a class="hidden lg:flex items-center gap-2 lg:gap-2.5 group no-underline shrink-0 lg:mr-3 xl:mr-6" href="/">
            <svg class="h-6 w-6 xl:h-7 xl:w-7 rounded-[4px] shadow-sm transition-transform group-hover:scale-105" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
                <rect width="32" height="32" fill="#f8fafc" rx="4" class="dark:fill-slate-800" />
                <g transform="translate(4, 4)">
                    <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="#2563EB" class="dark:fill-twprobe-blue" />
                </g>
            </svg>
            <span class="font-bold text-slate-800 dark:text-slate-100 text-[0.95rem] xl:text-[1.05rem] tracking-wide whitespace-nowrap">TWProbe 深層架構中樞</span>
         </a>

         <!-- 桌機版靠左分類 / 行動版絕對定位展開選單 -->
         <div id="mobile-menu" class="hidden lg:flex flex-col lg:flex-row items-stretch lg:items-center gap-1 lg:gap-2 xl:gap-4 text-[0.85rem] xl:text-[0.9rem] font-bold text-slate-500 dark:text-slate-400 w-full lg:w-auto absolute top-full left-0 bg-white/95 dark:bg-slate-950/95 backdrop-blur-xl lg:bg-transparent lg:dark:bg-transparent px-4 py-3 lg:p-0 border-b border-slate-200 dark:border-slate-800 shadow-xl lg:shadow-none lg:static lg:border-none lg:border-l lg:border-slate-200 lg:dark:border-slate-800/80 lg:pl-3 xl:pl-6 transition-all z-10 shrink-0">
           <a href="/macro-cycles" class="hover:text-blue-600 dark:hover:text-twprobe-blue transition-colors no-underline block w-full lg:w-auto py-2.5 lg:py-0 border-b lg:border-none border-slate-100 dark:border-slate-800/80 whitespace-nowrap">宏觀週期</a>
           <a href="/capital-defense" class="hover:text-blue-600 dark:hover:text-twprobe-blue transition-colors no-underline block w-full lg:w-auto py-2.5 lg:py-0 border-b lg:border-none border-slate-100 dark:border-slate-800/80 whitespace-nowrap">資本防禦</a>
           <a href="/physical-boundaries" class="hover:text-blue-600 dark:hover:text-twprobe-blue transition-colors no-underline block w-full lg:w-auto py-2.5 lg:py-0 whitespace-nowrap">實體邊界</a>
         </div>
       </div>

       <!-- 區域 2: 右側工具群合集 (Theme + SYSTEM ONLINE + Buttons CTA) -->
       <div class="flex items-center justify-end flex-grow lg:flex-grow-0 gap-1 lg:gap-1.5 xl:gap-3 shrink-1 min-w-0">
         <!-- 太陽/月亮 明暗切換 -->
         <div class="shrink-0 -mx-1 lg:mx-0">
           <ThemeToggle />
         </div>

         <!-- SYSTEM ONLINE Badge (自適應延展) -->
         <div class="flex-grow flex justify-center lg:justify-start shrink lg:w-[260px] xl:w-[300px] mx-1 lg:mx-0 min-w-0">
           <div class="flex items-center gap-1.5 lg:gap-2 xl:gap-3 bg-slate-100/80 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 h-8 xl:h-9 px-1.5 lg:px-2 shadow-inner md:px-3 rounded-md relative overflow-hidden group w-full justify-center box-border min-w-0">
             <div class="absolute inset-0 bg-blue-500/5 dark:bg-blue-400/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
             <div class="relative flex items-center justify-center w-1.5 h-1.5 xl:w-2 xl:h-2 shrink-0">
               <div class="absolute w-1.5 h-1.5 xl:w-2 xl:h-2 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.8)] animate-ping opacity-75"></div>
               <div class="relative w-1 h-1 xl:w-1.5 xl:h-1.5 rounded-full bg-blue-400 shadow-[0_0_5px_rgba(59,130,246,1)]"></div>
             </div>
             <span class="font-mono text-[8px] lg:text-[9.5px] xl:text-[12px] font-bold text-slate-600 dark:text-blue-400/90 tracking-wider xl:tracking-widest uppercase truncate min-w-0 block">System Online // Kernel Secured</span>
           </div>
         </div>

         <!-- 雙子星按鈕群組 -->
         <div class="flex items-center gap-1 lg:gap-1.5 xl:gap-2 shrink-0">
           <!-- 情報站互聯按鈕 (降級為：幽靈風格 Ghost Button - 輔助導覽) -->
           <a href="https://news.twprobe.com" class="inline-flex items-center justify-center h-8 xl:h-9 px-1.5 lg:px-2 xl:px-4 box-border text-[9px] lg:text-[11px] xl:text-xs font-bold font-sans tracking-wider xl:tracking-widest text-slate-600 dark:text-slate-300 bg-transparent hover:bg-slate-100 dark:hover:bg-slate-800/80 border border-slate-300 dark:border-slate-700 hover:border-slate-400 dark:hover:border-slate-500 hover:scale-[1.02] active:scale-95 rounded-md transition-all shadow-sm no-underline whitespace-nowrap">
              政策指標 ↗
           </a>

           <!-- 回到主站按鈕 (升級為：主視覺湛藍色 Button - 匯聚流量) -->
           <a href="https://twprobe.com" class="inline-flex items-center justify-center h-8 xl:h-9 px-1.5 lg:px-2 xl:px-4 box-border text-[9px] lg:text-[11px] xl:text-xs font-bold font-sans tracking-wider xl:tracking-widest text-white bg-blue-600 hover:bg-blue-700 dark:bg-twprobe-blue dark:hover:bg-blue-500 hover:scale-[1.02] active:scale-95 rounded-md transition-all shadow-sm ring-1 ring-blue-700/50 no-underline whitespace-nowrap">
              TWProbe 房產觀測站
           </a>
         </div>
       </div>
    </div>

  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        mobileMenu.classList.toggle('flex');
      });
    }
  });
</script>
