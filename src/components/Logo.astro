<svg class="logo-vector" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path 
        d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
        fill="var(--accent-blue)" 
    />
</svg>

<style>
    .logo-vector {
        width: 42px;
        height: 42px;
        /* 移除舊的光影和漸層定義 */
        fill: none !important; 
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s ease;
    }
    a:hover .logo-vector {
        transform: scale(1.08) translateY(-2px);
        filter: drop-shadow(0 4px 12px rgba(43, 108, 176, 0.3));
    }
</style>