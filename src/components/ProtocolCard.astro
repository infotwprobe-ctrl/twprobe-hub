---
interface Props {
  post: any;
}
const { post } = Astro.props;
---
<a
  href={post.url}
  class="group bg-white/60 dark:bg-slate-900/60 backdrop-blur-sm border border-slate-200 dark:border-slate-800/80 rounded-xl p-6 hover:border-blue-400 dark:hover:border-slate-600 hover:shadow-md dark:shadow-none hover:bg-white dark:hover:bg-slate-800/80 transition-all duration-300 flex flex-col h-full justify-between"
>
  <div>
    <div class="flex items-center gap-3 mb-3">
      <span class="font-mono text-[10px] font-bold text-slate-500 dark:text-slate-400 tracking-widest bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded">
        {post.frontmatter.docId}
      </span>
    </div>
    <h3 class="text-lg font-bold text-slate-800 dark:text-slate-200 leading-snug mb-3 group-hover:text-blue-600 dark:group-hover:text-twprobe-blue transition-colors">
      {post.frontmatter.title}
    </h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed line-clamp-3">
      {post.frontmatter.abstract}
    </p>
  </div>
</a>
