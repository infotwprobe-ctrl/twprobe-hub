---
// ==============================================
// TWProbe Hub Terminal (V4.0 - The Architect Edition)
// Architecture: 100% Pure CSS / 0 External Requests / Living System
// ==============================================

const brandName = "TWProbe";
const mainSiteUrl = "https://twprobe.com";
const hubUrl = "https://hub.twprobe.com/";

// 靜態資源路徑
const ogImage = `${hubUrl}og-social-preview.jpg`;
const logoPng = `${hubUrl}logo.png`;
const faviconPng = `${hubUrl}favicon.png`;

// 核心資料庫 (The Vault)
const pillars = [
  {
    title: "交易與持有",
    slug: "real-estate-holding",
    desc: "交易流程與資產管理",
    topics: ["購屋流程", "房產銷售", "驗屋重點", "租賃指南", "室內裝修", "管理維護"]
  },
  {
    title: "開發與工程",
    slug: "development-engineering",
    desc: "土地價值與營造細節",
    topics: ["土地開發", "營造工程", "建商評估", "建案分析", "建築設計", "都更危老"]
  },
  {
    title: "投資與法規",
    slug: "investment-regulation",
    desc: "稅務法規與市場趨勢",
    topics: ["市場趨勢", "區域發展", "房貸理財", "法規稅務", "投資策略", "商用房產"]
  },
];

// 精銳分發陣列 (The Elite Trinity) - 替換 Reddit 為 Medium (MONOLITH)
const trinity = [
  { id: "signal", concept: "SIGNAL", name: "X", url: "https://x.com/probe54670", color: "#000000", glow: "rgba(0,0,0,0.15)" },
  { id: "monolith", concept: "MONOLITH", name: "Medium", url: "https://medium.com/@twprobe", color: "#000000", glow: "rgba(0,0,0,0.15)" },
  { id: "prism", concept: "PRISM", name: "Pinterest", url: "https://www.pinterest.com/infotwprobe/", color: "#E60023", glow: "rgba(230,0,35,0.2)" }
];

const footerLinks = [
    { name: "關於本站", u: "https://twprobe.com/about-twprobe/" },
    { name: "網站地圖", u: "https://twprobe.com/sitemap/" },
    { name: "情報矩陣", u: "https://hub.twprobe.com/" },
    { name: "服務條款", u: "https://twprobe.com/terms-of-service/" },
    { name: "隱私政策", u: "https://twprobe.com/privacy-policy/" },
    { name: "免責聲明", u: "https://twprobe.com/disclaimer/" },
];
---

<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TWProbe 核心情報終端</title>
    <meta name="description" content="TWProbe 核心情報終端。整合台灣房產交易、開發與投資三大脈絡。">
    <link rel="canonical" href={hubUrl} />
    <link rel="icon" type="image/png" sizes="96x96" href={faviconPng} />
    
    <style>
        :root {
            --bg-body: #F8FAFC; 
            --text-dark: #0F172A;
            --text-muted: #64748B;
            --border-light: rgba(226, 232, 240, 0.8);
            --border-hover: rgba(203, 213, 225, 1);
            --accent-blue: #2B6CB0;
            --accent-bg: #EFF6FF;
            
            --font-stack: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        /* 活體系統動畫 */
        @keyframes fadeUp {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        @keyframes serverPulse {
            0%, 100% { opacity: 0.2; text-shadow: none; }
            50% { opacity: 1; text-shadow: 0 0 6px rgba(43, 108, 176, 0.6); }
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-body);
            color: var(--text-dark);
            font-family: var(--font-stack);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            -webkit-font-smoothing: antialiased;
            
            /* The Blueprint Grid (微弱工程網格) + Radial Glow */
            background-image: 
                radial-gradient(circle at 50% 0%, #FFFFFF 0%, transparent 80%),
                linear-gradient(rgba(43, 108, 176, 0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(43, 108, 176, 0.025) 1px, transparent 1px);
            background-size: 100% 100%, 32px 32px, 32px 32px;
            background-position: center top, center center, center center;
        }

        .container {
            width: 100%;
            max-width: 900px;
            padding: 4rem 1.5rem 2rem;
            box-sizing: border-box;
            flex: 1;
            display: flex;
            flex-direction: column;
            animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Header 精神圖騰 */
        .header {
            text-align: center;
            margin-bottom: 4rem;
        }
        .brand-link {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
            color: var(--text-dark);
            transition: color 0.3s;
        }
        .brand-link:hover { color: var(--accent-blue); }
        .logo-svg {
            width: 42px; 
            height: 42px;
            fill: var(--accent-blue);
        }
        .brand-name {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.04em;
        }
        .spirit-tags {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            margin-top: 1.2rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            letter-spacing: 0.4em;
            font-weight: 700;
            padding-left: 0.4em;
        }
        .spirit-tags .dot {
            color: var(--accent-blue);
            font-size: 1.2rem;
            line-height: 0;
            letter-spacing: 0;
        }
        /* 伺服器呼吸燈特效 (交錯閃爍) */
        .pulse-1 { animation: serverPulse 3s infinite ease-in-out; }
        .pulse-2 { animation: serverPulse 3s infinite ease-in-out; animation-delay: 1.5s; }

        /* 核心資料庫 (The Vault) - 冰霜玻璃材質 */
        .pillar-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1.5rem;
            margin-bottom: 5.5rem;
        }
        .pillar-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 1);
            border-radius: 14px;
            padding: 1.5rem;
            box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.03), inset 0 0 0 1px rgba(255,255,255,0.5);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            opacity: 0;
        }
        .pillar-card:nth-child(1) { animation: fadeUp 0.6s 0.15s forwards; }
        .pillar-card:nth-child(2) { animation: fadeUp 0.6s 0.25s forwards; }
        .pillar-card:nth-child(3) { animation: fadeUp 0.6s 0.35s forwards; }
        
        .pillar-card:hover {
            transform: translateY(-6px);
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 12px 30px -5px rgba(0, 0, 0, 0.08), inset 0 0 0 1px rgba(255,255,255,1);
        }
        .pillar-header {
            text-align: center;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 1.2rem;
            margin-bottom: 1.2rem;
        }
        .pillar-title-link {
            text-decoration: none;
            color: var(--text-dark);
            display: inline-block;
            transition: color 0.3s ease;
        }
        .pillar-title-link:hover { color: var(--accent-blue); }
        .pillar-title {
            font-size: 1.25rem;
            font-weight: 800;
            margin: 0 0 0.4rem 0;
            letter-spacing: 0.02em;
        }
        .pillar-desc {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin: 0;
            font-weight: 600;
        }
        .topic-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.6rem;
        }
        .topic-link {
            background: rgba(248, 250, 252, 0.6);
            color: var(--text-dark);
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.6rem;
            border-radius: 8px;
            text-align: center;
            transition: all 0.25s ease;
            border: 1px solid transparent;
        }
        .topic-link:hover {
            background: var(--accent-bg);
            color: var(--accent-blue);
            border-color: rgba(43, 108, 176, 0.15);
            transform: scale(1.03);
            box-shadow: 0 2px 8px rgba(43, 108, 176, 0.1);
        }

        /* 精銳分發陣列 (The Elite Trinity) */
        .trinity-section {
            margin-top: auto;
            text-align: center;
            padding-bottom: 2rem;
            opacity: 0;
            animation: fadeUp 0.8s 0.5s forwards;
        }
        .trinity-grid {
            display: flex;
            justify-content: center;
            gap: 4.5rem;
            flex-wrap: wrap;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border-light);
            position: relative;
        }
        /* 中間的極細引導線 */
        .trinity-grid::before {
            content: '';
            position: absolute;
            top: -1px;
            left: 50%;
            transform: translateX(-50%);
            width: 40px;
            height: 2px;
            background: var(--text-muted);
            border-radius: 2px;
        }
        
        .trinity-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            padding-top: 1.5rem;
        }
        .trinity-concept {
            font-size: 0.65rem;
            font-weight: 800;
            color: var(--text-muted);
            letter-spacing: 0.2em;
            margin-bottom: 0.8rem;
            transition: color 0.3s ease;
        }
        .trinity-icon {
            width: 36px; 
            height: 36px;
            fill: var(--text-muted);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            margin-bottom: 0.6rem;
        }
        .trinity-name {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-dark);
            transition: color 0.3s ease;
            opacity: 0.6;
        }

        /* Hover 爆發 */
        .trinity-item:hover { transform: translateY(-5px); }
        .trinity-item:hover .trinity-concept { color: var(--hover-color); }
        .trinity-item:hover .trinity-name { opacity: 1; color: var(--hover-color); }
        .trinity-item:hover .trinity-icon {
            fill: var(--hover-color);
            filter: drop-shadow(0 8px 16px var(--hover-glow));
            transform: scale(1.2);
        }

        /* Footer */
        .footer {
            width: 100%;
            border-top: 1px solid var(--border-light);
            padding: 2.5rem 0;
            text-align: center;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(8px);
        }
        .footer-nav {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 1.5rem;
            margin-bottom: 1.25rem;
        }
        .footer-nav a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 600;
            transition: color 0.2s;
        }
        .footer-nav a:hover { color: var(--accent-blue); }
        .copyright {
            font-size: 0.7rem;
            color: #94A3B8;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="container">
        <header class="header">
            <a href={mainSiteUrl} class="brand-link">
                <svg class="logo-svg" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
                <span class="brand-name">{brandName}</span>
            </a>
            <div class="spirit-tags">
                <span>數據</span><span class="dot pulse-1">·</span><span>結構</span><span class="dot pulse-2">·</span><span>真理</span>
            </div>
        </header>

        <main class="pillar-grid">
            {pillars.map(p => (
                <div class="pillar-card">
                    <div class="pillar-header">
                        <a href={`${mainSiteUrl}/${p.slug}/`} class="pillar-title-link">
                            <h2 class="pillar-title">{p.title}</h2>
                        </a>
                        <p class="pillar-desc">{p.desc}</p>
                    </div>
                    <div class="topic-grid">
                        {p.topics.map(t => (
                            <a href={`${mainSiteUrl}/${p.slug}/`} class="topic-link">{t}</a>
                        ))}
                    </div>
                </div>
            ))}
        </main>

        <section class="trinity-section">
            <div class="trinity-grid">
                {trinity.map(t => (
                    <a href={t.url} target="_blank" rel="me noopener noreferrer" class="trinity-item" style={`--hover-color: ${t.color}; --hover-glow: ${t.glow};`}>
                        <span class="trinity-concept">{t.concept}</span>
                        <svg class="trinity-icon" viewBox="0 0 24 24">
                            {t.id === 'signal' && <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>}
                            {/* 替換為 Medium 官方 SVG 路徑 */}
                            {t.id === 'monolith' && <path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42c1.87 0 3.38 2.88 3.38 6.42M24 12c0 3.11-.53 5.62-1.18 5.62-.66 0-1.18-2.51-1.18-5.62s.52-5.62 1.18-5.62c.65 0 1.18 2.51 1.18 5.62"/>}
                            {t.id === 'prism' && <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.399.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.951-7.252 4.173 0 7.41 2.967 7.41 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.367 18.62 0 12.017 0z"/>}
                        </svg>
                        <span class="trinity-name">{t.name}</span>
                    </a>
                ))}
            </div>
        </section>
    </div>

    <footer class="footer">
        <nav class="footer-nav">
            {footerLinks.map(f => (
                <a href={f.u}>{f.name}</a>
            ))}
        </nav>
        <p class="copyright">© 2026 {brandName}. ALL RIGHTS RESERVED.</p>
    </footer>

</body>
</html>
