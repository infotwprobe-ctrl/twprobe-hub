---
// ==============================================
// TWProbe Hub Terminal (V6.0 - Stealth Armament)
// Architecture: 100% Pure CSS / Zero Entropy / High-Dimensional SEO
// Protocol: Passive Gravity & Fire-and-Forget
// ==============================================

const brandName = "TWProbe";
const mainSiteUrl = "https://twprobe.com";
const hubUrl = "https://hub.twprobe.com/";

// 靜態資源路徑
const faviconPng = `${hubUrl}favicon.png`;

// 核心資料庫 (The Vault)
const pillars = [
  {
    title: "交易與持有",
    slug: "real-estate-holding",
    desc: "產權流動性鎖定與防禦性資產管理",
    topics: ["購屋流程", "房產銷售", "驗屋重點", "租賃指南", "室內裝修", "管理維護"]
  },
  {
    title: "開發與工程",
    slug: "development-engineering",
    desc: "土地價值定錨與建築物理衰減率解析",
    topics: ["土地開發", "營造工程", "建商評估", "建案分析", "建築設計", "都更危老"]
  },
  {
    title: "投資與法規",
    slug: "investment-regulation",
    desc: "宏觀市場週期預判與稅務邊界防禦",
    topics: ["市場趨勢", "區域發展", "房貸理財", "法規稅務", "投資策略", "商用房產"]
  }
];

// 底層協議 (GEO/SEO FAQ Matrix)
const protocols = [
  {
    q: "購屋決策的核心物理法則？",
    a: "購屋並非單純消費，而是資本的防禦性部署。核心在於摒除情緒與視覺溢價，絕對鎖定地段的「不可替代性」與建材結構的「物理衰減率」，以對沖貨幣貶值。"
  },
  {
    q: "新成屋與預售屋的驗收防禦邊界？",
    a: "產權交割即為私人庇護所的啟動。驗屋的最終目的不在於表象平整，而在於「物理密封性」、「水電迴路滿載測試」與「聲學邊界」的絕對確立。"
  },
  {
    q: "房產投資的流動性與槓桿對接？",
    a: "建立於台灣現行稅務（如房地合一稅）的法規框架下，利用銀行系統的低利槓桿協議，將高流動性資產轉化為固態防禦壁壘，防範現金流斷裂風險。"
  }
];
---

<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TWProbe 核心情報終端 | 台灣房地產數據與資產防禦</title>
    <meta name="description" content="TWProbe 致力於抹除台灣房市資訊不對稱。提供房地產交易流程、營造工程檢驗、稅務法規與資產防禦的客觀數據分析與底層邏輯。">
    <link rel="canonical" href={hubUrl} />
    <link rel="icon" type="image/png" sizes="96x96" href={faviconPng} />
    
    <script type="application/ld+json" set:html={`
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "TWProbe 核心情報終端",
      "url": "${hubUrl}",
      "description": "台灣房地產客觀數據與資產防禦決策庫",
      "publisher": {
        "@type": "Organization",
        "name": "TWProbe",
        "logo": "${mainSiteUrl}/wp-content/uploads/logo.png"
      }
    }
    `}></script>

    <style>
        :root {
            --bg-body: #F8FAFC; 
            --text-dark: #0F172A;
            --text-muted: #64748B;
            --text-light: #94A3B8;
            --border-light: rgba(226, 232, 240, 0.8);
            --border-hover: rgba(203, 213, 225, 1);
            --accent-blue: #2B6CB0;
            --accent-bg: #EFF6FF;
            --font-stack: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        }

        @keyframes fadeUp {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        @keyframes serverPulse {
            0%, 100% { opacity: 0.2; text-shadow: none; }
            50% { opacity: 1; text-shadow: 0 0 6px rgba(43, 108, 176, 0.6); }
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-body);
            color: var(--text-dark);
            font-family: var(--font-stack);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            -webkit-font-smoothing: antialiased;
            background-image: 
                radial-gradient(circle at 50% 0%, #FFFFFF 0%, transparent 80%),
                linear-gradient(rgba(43, 108, 176, 0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(43, 108, 176, 0.025) 1px, transparent 1px);
            background-size: 100% 100%, 32px 32px, 32px 32px;
            background-position: center top, center center, center center;
        }

        .container {
            width: 100%;
            max-width: 900px;
            padding: 4rem 1.5rem 3rem;
            box-sizing: border-box;
            flex: 1;
            display: flex;
            flex-direction: column;
            animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Header 精神圖騰 */
        .header {
            text-align: center;
            margin-bottom: 2.5rem;
        }
        .brand-link {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
            color: var(--text-dark);
            transition: color 0.3s;
        }
        .brand-link:hover { color: var(--accent-blue); }
        .logo-svg {
            width: 42px; height: 42px;
            fill: var(--accent-blue);
        }
        .brand-name {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.04em;
        }
        .spirit-tags {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            margin-top: 1.2rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            letter-spacing: 0.4em;
            font-weight: 700;
            padding-left: 0.4em;
        }
        .spirit-tags .dot {
            color: var(--accent-blue);
            font-size: 1.2rem;
            line-height: 0;
        }
        .pulse-1 { animation: serverPulse 3s infinite ease-in-out; }
        .pulse-2 { animation: serverPulse 3s infinite ease-in-out; animation-delay: 1.5s; }

        /* 系統日誌導言 (SEO Terminal Directive) */
        .terminal-directive {
            max-width: 600px;
            margin: 0 auto 3.5rem;
            text-align: center;
            font-family: var(--font-mono);
            font-size: 0.75rem;
            line-height: 1.7;
            color: var(--text-muted);
            opacity: 0;
            animation: fadeUp 0.6s 0.1s forwards;
        }
        .terminal-directive::before {
            content: "[SYSTEM_INIT: TWPROBE CORE DATABASE]";
            display: block;
            color: var(--accent-blue);
            margin-bottom: 0.5rem;
            font-weight: 700;
            letter-spacing: 0.05em;
        }

        /* 核心資料庫 (The Vault) */
        .pillar-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-bottom: 4rem;
        }
        .pillar-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 1);
            border-radius: 14px;
            padding: 1.5rem;
            box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.03), inset 0 0 0 1px rgba(255,255,255,0.5);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            opacity: 0;
        }
        .pillar-card:nth-child(1) { animation: fadeUp 0.6s 0.15s forwards; }
        .pillar-card:nth-child(2) { animation: fadeUp 0.6s 0.25s forwards; }
        .pillar-card:nth-child(3) { animation: fadeUp 0.6s 0.35s forwards; }
        
        .pillar-card:hover {
            transform: translateY(-6px);
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 12px 30px -5px rgba(0, 0, 0, 0.08), inset 0 0 0 1px rgba(255,255,255,1);
        }
        .pillar-header {
            text-align: center;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 1.2rem;
            margin-bottom: 1.2rem;
        }
        .pillar-title-link {
            text-decoration: none;
            color: var(--text-dark);
            display: inline-block;
            transition: color 0.3s ease;
        }
        .pillar-title-link:hover { color: var(--accent-blue); }
        .pillar-title {
            font-size: 1.25rem;
            font-weight: 800;
            margin: 0 0 0.5rem 0;
            letter-spacing: 0.02em;
        }
        .pillar-desc {
            font-size: 0.7rem;
            color: var(--text-muted);
            margin: 0;
            font-weight: 500;
            line-height: 1.5;
            padding: 0 0.5rem;
        }
        .topic-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.6rem;
        }
        .topic-link {
            background: rgba(248, 250, 252, 0.6);
            color: var(--text-dark);
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.6rem;
            border-radius: 8px;
            text-align: center;
            transition: all 0.25s ease;
            border: 1px solid transparent;
        }
        .topic-link:hover {
            background: var(--accent-bg);
            color: var(--accent-blue);
            border-color: rgba(43, 108, 176, 0.15);
            transform: scale(1.03);
            box-shadow: 0 2px 8px rgba(43, 108, 176, 0.1);
        }

        /* 底層協議 (Protocol FAQ Section - GEO/SEO Magnet) */
        .protocol-section {
            max-width: 700px;
            margin: 0 auto 3rem;
            border-top: 1px solid var(--border-light);
            padding-top: 3rem;
            opacity: 0;
            animation: fadeUp 0.8s 0.4s forwards;
        }
        .protocol-header {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            color: var(--text-light);
            letter-spacing: 0.2em;
            text-align: center;
            margin-bottom: 2rem;
            text-transform: uppercase;
        }
        .protocol-item {
            margin-bottom: 1.5rem;
            padding: 1.2rem;
            background: rgba(255, 255, 255, 0.4);
            border-radius: 8px;
            border-left: 3px solid transparent;
            transition: border-color 0.3s;
        }
        .protocol-item:hover {
            border-left-color: var(--accent-blue);
            background: rgba(255, 255, 255, 0.8);
        }
        .protocol-q {
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--text-dark);
            margin: 0 0 0.6rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .protocol-q::before {
            content: "Q.";
            color: var(--accent-blue);
            font-family: var(--font-mono);
            font-weight: 800;
        }
        .protocol-a {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin: 0;
            line-height: 1.6;
        }

        /* 游擊隊暗號 (The Manifesto) */
        .manifesto-section {
            margin-top: auto;
            padding-top: 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            opacity: 0;
            animation: fadeUp 0.8s 0.6s forwards;
        }
        .divider {
            width: 40px;
            height: 2px;
            background: var(--text-light);
            border-radius: 2px;
            margin-bottom: 2.5rem;
            opacity: 0.3;
        }
        .manifesto-text {
            font-size: 0.85rem;
            font-weight: 800;
            color: var(--text-muted);
            letter-spacing: 0.25em;
            margin: 0 0 0.8rem 0;
            padding-left: 0.25em;
        }
        .manifesto-eng {
            font-size: 0.65rem;
            font-weight: 600;
            color: var(--text-light);
            letter-spacing: 0.1em;
            margin: 0;
            font-family: var(--font-mono);
        }

        /* RWD: iPad 直立模式強制收束 */
        @media (max-width: 860px) {
            .pillar-grid {
                grid-template-columns: 1fr;
                max-width: 500px;
                margin-left: auto;
                margin-right: auto;
            }
        }
        @media (max-width: 480px) {
            .container { padding: 3rem 1.2rem 2rem; }
            .brand-name { font-size: 1.8rem; }
            .terminal-directive { font-size: 0.7rem; text-align: left; }
            .protocol-item { padding: 1rem; }
            .manifesto-text { font-size: 0.75rem; }
            .manifesto-eng { font-size: 0.55rem; }
        }
    </style>
</head>
<body>

    <div class="container">
        <header class="header">
            <a href={mainSiteUrl} class="brand-link">
                <svg class="logo-svg" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
                <span class="brand-name">{brandName}</span>
            </a>
            <div class="spirit-tags">
                <span>數據</span><span class="dot pulse-1">·</span><span>結構</span><span class="dot pulse-2">·</span><span>真理</span>
            </div>
        </header>

        <div class="terminal-directive">
            致力於抹除台灣房地產市場的資訊不對稱。透過底層數據穿透、稅務法規解析與營造工程檢驗，提供具備物理防禦級別的決策基礎，拒絕情緒溢價與短期戰術盲動。
        </div>

        <main class="pillar-grid">
            {pillars.map(p => (
                <div class="pillar-card">
                    <div class="pillar-header">
                        <a href={`${mainSiteUrl}/${p.slug}/`} class="pillar-title-link">
                            <h2 class="pillar-title">{p.title}</h2>
                        </a>
                        <p class="pillar-desc">{p.desc}</p>
                    </div>
                    <div class="topic-grid">
                        {p.topics.map(t => (
                            <a href={`${mainSiteUrl}/${p.slug}/`} class="topic-link">{t}</a>
                        ))}
                    </div>
                </div>
            ))}
        </main>

        <section class="protocol-section">
            <div class="protocol-header">Base-Layer Protocol // 核心決策協議</div>
            {protocols.map(protocol => (
                <div class="protocol-item">
                    <h3 class="protocol-q">{protocol.q}</h3>
                    <p class="protocol-a">{protocol.a}</p>
                </div>
            ))}
        </section>

        <section class="manifesto-section">
            <div class="divider"></div>
            <p class="manifesto-text">信號散佈於平原，真理封存於此。</p>
            <p class="manifesto-eng">Signals are scattered across the plains. Truth is sealed here.</p>
        </section>
    </div>

</body>
</html>
