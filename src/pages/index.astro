---
// ==============================================
// TWProbe Hub - Main Index Terminal
// Target: Automated Routing / WebSite Schema / Zero Friction
// ==============================================

// 1. 啟動物理掃描：自動抓取 pages 底下所有的 .md 檔案
// 這行代碼是自動化的靈魂，它會爬取所有子資料夾中的文章
const allPosts = await Astro.glob("./**/*.md");

// 2. 首頁全域物理常數
const siteTitle = "TWProbe 核心情報終端 | 實體資產與宏觀週期";
const siteDescription =
  "剝離情緒溢價，直探底層邏輯。探討在宏觀週期與貨幣政策下，如何透過台灣實體房地產建構資本防禦矩陣。";
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://hub.twprobe.com",
);

// 3. 注入全站等級 JSON-LD (引導 AI 與 Google 爬蟲)
const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "TWProbe Hub",
  url: "https://hub.twprobe.com/",
  description: siteDescription,
  publisher: {
    "@type": "Organization",
    name: "TWProbe",
  },
};
---

<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="any" />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <style is:global>
      :root {
        --bg-paper: #fafafa;
        --text-main: #111827;
        --text-muted: #4b5563;
        --border-line: #e5e7eb;
        --font-mono:
          ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
          "Liberation Mono", monospace;
        --font-sans: system-ui, -apple-system, sans-serif;
      }
      body {
        background-color: var(--bg-paper);
        color: var(--text-main);
        font-family: var(--font-sans);
        margin: 0;
        -webkit-font-smoothing: antialiased;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <nav
      class="border-b border-gray-200 bg-white px-6 py-4 flex justify-between items-center font-mono text-xs tracking-widest text-gray-500 uppercase"
    >
      <span>TWPROBE // KERNEL</span>
      <span class="text-green-600 font-bold">SYSTEM ONLINE</span>
    </nav>

    <main class="flex-grow max-w-4xl mx-auto w-full px-6 py-16">
      <header class="mb-16 border-b-2 border-black pb-12">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
          核心情報終端
        </h1>
        <p class="text-lg text-gray-600 max-w-2xl leading-relaxed">
          剝離市場的情緒溢價，下探事物的底層物理常數。這座節點專注於宏觀週期推演、資本防禦矩陣，以及台灣實體資產的絕對邊界。
        </p>
      </header>

      <section>
        <div
          class="flex items-center mb-8 font-mono text-sm font-bold tracking-widest uppercase"
        >
          <span class="w-2 h-2 bg-black mr-3"></span>
          INDEX / 實體論述索引
        </div>

        <div class="grid gap-6">
          {
            allPosts.map((post) => (
              <a
                href={post.url}
                class="group block bg-white border border-gray-200 p-6 hover:border-black transition-colors duration-200"
              >
                <div class="flex flex-col md:flex-row md:items-baseline gap-2 mb-3">
                  <span class="font-mono text-xs text-gray-400 tracking-wider">
                    {post.frontmatter.docId || "TWP-DOC"}
                  </span>
                  <h2 class="text-xl font-bold group-hover:text-blue-600 transition-colors">
                    {post.frontmatter.title}
                  </h2>
                </div>
                <p class="text-gray-600 text-sm leading-relaxed">
                  {post.frontmatter.abstract}
                </p>
                <div class="mt-4 font-mono text-xs text-gray-400 group-hover:text-black transition-colors flex items-center">
                  INITIALIZE SEQUENCE <span class="ml-2">→</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </main>

    <footer
      class="border-t border-gray-200 bg-white py-8 text-center font-mono text-xs text-gray-400 tracking-widest"
    >
      © {new Date().getFullYear()} TWPROBE. ALL SYSTEMS NOMINAL.
    </footer>
  </body>
</html>
