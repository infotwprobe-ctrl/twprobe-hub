---
// ==============================================
// TWProbe Hub Terminal (V5.0 - The CORTEX Edition)
// Architecture: 100% Pure CSS / 0 External Requests / Zero Entropy
// Protocol: Fire and Forget
// ==============================================

const brandName = "TWProbe";
const mainSiteUrl = "https://twprobe.com";
const hubUrl = "https://hub.twprobe.com/";

// 靜態資源路徑
const ogImage = `${hubUrl}og-social-preview.jpg`;
const logoPng = `${hubUrl}logo.png`;
const faviconPng = `${hubUrl}favicon.png`;

// 核心資料庫 (The Vault)
const pillars = [
  {
    title: "交易與持有",
    slug: "real-estate-holding",
    desc: "交易流程與資產管理",
    topics: ["購屋流程", "房產銷售", "驗屋重點", "租賃指南", "室內裝修", "管理維護"]
  },
  {
    title: "開發與工程",
    slug: "development-engineering",
    desc: "土地價值與營造細節",
    topics: ["土地開發", "營造工程", "建商評估", "建案分析", "建築設計", "都更危老"]
  },
  {
    title: "投資與法規",
    slug: "investment-regulation",
    desc: "稅務法規與市場趨勢",
    topics: ["市場趨勢", "區域發展", "房貸理財", "法規稅務", "投資策略", "商用房產"]
  },
];
---

<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TWProbe 核心情報終端</title>
    <meta name="description" content="信號散佈於平原，真理封存於此。">
    <link rel="canonical" href={hubUrl} />
    <link rel="icon" type="image/png" sizes="96x96" href={faviconPng} />
    
    <style>
        :root {
            --bg-body: #F8FAFC; 
            --text-dark: #0F172A;
            --text-muted: #64748B;
            --border-light: rgba(226, 232, 240, 0.8);
            --border-hover: rgba(203, 213, 225, 1);
            --accent-blue: #2B6CB0;
            --accent-bg: #EFF6FF;
            
            --font-stack: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        /* 活體系統動畫 */
        @keyframes fadeUp {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        @keyframes serverPulse {
            0%, 100% { opacity: 0.2; text-shadow: none; }
            50% { opacity: 1; text-shadow: 0 0 6px rgba(43, 108, 176, 0.6); }
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-body);
            color: var(--text-dark);
            font-family: var(--font-stack);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            -webkit-font-smoothing: antialiased;
            
            /* The Blueprint Grid (微弱工程網格) + Radial Glow */
            background-image: 
                radial-gradient(circle at 50% 0%, #FFFFFF 0%, transparent 80%),
                linear-gradient(rgba(43, 108, 176, 0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(43, 108, 176, 0.025) 1px, transparent 1px);
            background-size: 100% 100%, 32px 32px, 32px 32px;
            background-position: center top, center center, center center;
        }

        .container {
            width: 100%;
            max-width: 900px;
            padding: 4rem 1.5rem 3rem;
            box-sizing: border-box;
            flex: 1;
            display: flex;
            flex-direction: column;
            animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Header 精神圖騰 */
        .header {
            text-align: center;
            margin-bottom: 4rem;
        }
        .brand-link {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
            color: var(--text-dark);
            transition: color 0.3s;
        }
        .brand-link:hover { color: var(--accent-blue); }
        .logo-svg {
            width: 42px; 
            height: 42px;
            fill: var(--accent-blue);
        }
        .brand-name {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.04em;
        }
        .spirit-tags {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            margin-top: 1.2rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            letter-spacing: 0.4em;
            font-weight: 700;
            padding-left: 0.4em;
        }
        .spirit-tags .dot {
            color: var(--accent-blue);
            font-size: 1.2rem;
            line-height: 0;
            letter-spacing: 0;
        }
        .pulse-1 { animation: serverPulse 3s infinite ease-in-out; }
        .pulse-2 { animation: serverPulse 3s infinite ease-in-out; animation-delay: 1.5s; }

        /* 核心資料庫 (The Vault) */
        .pillar-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        .pillar-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 1);
            border-radius: 14px;
            padding: 1.5rem;
            box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.03), inset 0 0 0 1px rgba(255,255,255,0.5);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            opacity: 0;
        }
        .pillar-card:nth-child(1) { animation: fadeUp 0.6s 0.15s forwards; }
        .pillar-card:nth-child(2) { animation: fadeUp 0.6s 0.25s forwards; }
        .pillar-card:nth-child(3) { animation: fadeUp 0.6s 0.35s forwards; }
        
        .pillar-card:hover {
            transform: translateY(-6px);
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 12px 30px -5px rgba(0, 0, 0, 0.08), inset 0 0 0 1px rgba(255,255,255,1);
        }
        .pillar-header {
            text-align: center;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 1.2rem;
            margin-bottom: 1.2rem;
        }
        .pillar-title-link {
            text-decoration: none;
            color: var(--text-dark);
            display: inline-block;
            transition: color 0.3s ease;
        }
        .pillar-title-link:hover { color: var(--accent-blue); }
        .pillar-title {
            font-size: 1.25rem;
            font-weight: 800;
            margin: 0 0 0.4rem 0;
            letter-spacing: 0.02em;
        }
        .pillar-desc {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin: 0;
            font-weight: 600;
        }
        .topic-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.6rem;
        }
        .topic-link {
            background: rgba(248, 250, 252, 0.6);
            color: var(--text-dark);
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.6rem;
            border-radius: 8px;
            text-align: center;
            transition: all 0.25s ease;
            border: 1px solid transparent;
        }
        .topic-link:hover {
            background: var(--accent-bg);
            color: var(--accent-blue);
            border-color: rgba(43, 108, 176, 0.15);
            transform: scale(1.03);
            box-shadow: 0 2px 8px rgba(43, 108, 176, 0.1);
        }

        /* 游擊隊暗號 (The Manifesto) */
        .manifesto-section {
            margin-top: auto;
            padding-top: 4rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            opacity: 0;
            animation: fadeUp 0.8s 0.5s forwards;
        }
        .divider {
            width: 40px;
            height: 2px;
            background: var(--text-muted);
            border-radius: 2px;
            margin-bottom: 2.5rem;
            opacity: 0.4;
        }
        .manifesto-text {
            font-size: 0.85rem;
            font-weight: 800;
            color: var(--text-muted);
            letter-spacing: 0.25em;
            margin: 0 0 0.8rem 0;
            padding-left: 0.25em;
        }
        .manifesto-eng {
            font-size: 0.65rem;
            font-weight: 600;
            color: #94A3B8;
            letter-spacing: 0.1em;
            margin: 0;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        }

        /* RWD: iPad 直立模式強制收束 (Zero Entropy Grid) */
        @media (max-width: 860px) {
            .pillar-grid {
                grid-template-columns: 1fr;
                max-width: 500px;
                margin-left: auto;
                margin-right: auto;
            }
        }
        @media (max-width: 480px) {
            .container { padding: 3rem 1.2rem 2rem; }
            .brand-name { font-size: 1.8rem; }
            .manifesto-text { font-size: 0.75rem; }
            .manifesto-eng { font-size: 0.55rem; }
        }
    </style>
</head>
<body>

    <div class="container">
        <header class="header">
            <a href={mainSiteUrl} class="brand-link">
                <svg class="logo-svg" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
                <span class="brand-name">{brandName}</span>
            </a>
            <div class="spirit-tags">
                <span>數據</span><span class="dot pulse-1">·</span><span>結構</span><span class="dot pulse-2">·</span><span>真理</span>
            </div>
        </header>

        <main class="pillar-grid">
            {pillars.map(p => (
                <div class="pillar-card">
                    <div class="pillar-header">
                        <a href={`${mainSiteUrl}/${p.slug}/`} class="pillar-title-link">
                            <h2 class="pillar-title">{p.title}</h2>
                        </a>
                        <p class="pillar-desc">{p.desc}</p>
                    </div>
                    <div class="topic-grid">
                        {p.topics.map(t => (
                            <a href={`${mainSiteUrl}/${p.slug}/`} class="topic-link">{t}</a>
                        ))}
                    </div>
                </div>
            ))}
        </main>

        <section class="manifesto-section">
            <div class="divider"></div>
            <p class="manifesto-text">信號散佈於平原，真理封存於此。</p>
            <p class="manifesto-eng">Signals are scattered across the plains. Truth is sealed here.</p>
        </section>
    </div>

</body>
</html>
