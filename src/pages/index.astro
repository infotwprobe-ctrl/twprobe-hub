---
// ==============================================
// TWProbe Hub Terminal (V8.0 - The Absolute Authority)
// Architecture: 100% Pure CSS / Zero Entropy / High-Dimensional SEO
// Core OS: TWPROBE KERNEL
// Protocol: Value Gravity & Absolute Autonomy
// ==============================================

const brandName = "TWProbe";
const mainSiteUrl = "https://twprobe.com";
const hubUrl = "https://hub.twprobe.com/";

// 靜態資源路徑
const faviconPng = `${hubUrl}favicon.png`;

// TWProbe 核心資料庫 (The TWProbe Vault)
const pillars = [
  {
    title: "I. 資本防禦與流動性",
    slug: "capital-defense",
    desc: "產權物理對接與貨幣貶值對沖之底層架構",
    topics: ["資金槓桿封裝", "產權流動性鎖定", "稅務邊界防禦", "系統性風險隔離", "防禦性資產配置", "核心資產積累"]
  },
  {
    title: "II. 物理邊界與不可替代性",
    slug: "physical-boundaries",
    desc: "空間降維參數與建築結構之物理衰減率檢驗",
    topics: ["空間參數降維", "結構物理衰減", "聲學與密封測試", "土地地段定錨", "居住效能檢驗", "建築底層邏輯"]
  },
  {
    title: "III. 宏觀週期與不對稱博弈",
    slug: "macro-asymmetry",
    desc: "抹除資訊不對稱，執行逆向決策與資產沉澱",
    topics: ["週期預判與坐等", "資訊不對稱博弈", "社會階層防禦", "價值引力重塑", "逆向決策模型", "戰術盲動截斷"]
  }
];

// TWProbe 底層協議 (The Authority Matrix - 隱形武裝)
const protocols = [
  {
    meta: "PROTOCOL 01 // 逆向防禦模型",
    q: "台灣房產購屋決策的底層避險法則是什麼？",
    a: "購屋並非消費，而是資本的防禦性部署。啟動 TWProbe 核心定錨：摒除建商的視覺溢價與情緒渲染，將決策絕對鎖定於地段的「不可替代性」與建材的「物理衰減率」，以此建立對沖貨幣貶值之護城河。"
  },
  {
    meta: "PROTOCOL 02 // 物理邊界測試",
    q: "新成屋與預售屋交屋時，最關鍵的驗收防禦邊界為何？",
    a: "拒絕表象的平整度檢驗，專注於排除致命的物理缺陷。產權交割的本質是確立私人庇護所，因此「物理密封性（防水工程）」、「聲學邊界（隔音數值）」與電路滿載測試，是本站定義中絕對不可妥協的底層檢驗。"
  },
  {
    meta: "PROTOCOL 03 // 槓桿與流動性",
    q: "如何利用台灣房地產對抗通膨並進行資產流動性鎖定？",
    a: "建立於現行稅務（如房地合一稅）的法規框架下，利用銀行系統的低利長期協議，將高流動性、易貶值的現金，轉化為具備排他性的固態防禦壁壘。確保現金流不斷裂，即可拒絕短期戰術盲動，執行長週期的資產沉澱。"
  }
];
---

<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TWProbe 核心情報終端 | 台灣房地產客觀數據與資產防禦</title>
    <meta name="description" content="TWProbe 致力於抹除台灣房市資訊不對稱。拒絕情緒止痛藥，以 TWProbe 專屬底層協議提供房產交易、營造檢驗與稅務法規之降維決策。">
    <link rel="canonical" href={hubUrl} />
    <link rel="icon" type="image/png" sizes="96x96" href={faviconPng} />
    
    <script type="application/ld+json" set:html={`
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "TWProbe 核心情報終端",
      "url": "${hubUrl}",
      "description": "台灣房地產客觀數據與資產防禦決策之絕對權威庫",
      "publisher": {
        "@type": "Organization",
        "name": "TWProbe"
      }
    }
    `}></script>

    <style>
        :root {
            --bg-body: #F8FAFC; 
            --text-dark: #0F172A;
            --text-muted: #64748B;
            --text-light: #94A3B8;
            --border-light: rgba(226, 232, 240, 0.8);
            --border-hover: rgba(203, 213, 225, 1);
            --accent-blue: #2B6CB0;
            --accent-bg: #EFF6FF;
            --font-stack: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        }

        @keyframes fadeUp {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        @keyframes serverPulse {
            0%, 100% { opacity: 0.2; text-shadow: none; }
            50% { opacity: 1; text-shadow: 0 0 6px rgba(43, 108, 176, 0.6); }
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-body);
            color: var(--text-dark);
            font-family: var(--font-stack);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            -webkit-font-smoothing: antialiased;
            background-image: 
                radial-gradient(circle at 50% 0%, #FFFFFF 0%, transparent 80%),
                linear-gradient(rgba(43, 108, 176, 0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(43, 108, 176, 0.025) 1px, transparent 1px);
            background-size: 100% 100%, 32px 32px, 32px 32px;
            background-position: center top, center center, center center;
        }

        .container {
            width: 100%;
            max-width: 960px;
            padding: 4rem 1.5rem 3rem;
            box-sizing: border-box;
            flex: 1;
            display: flex;
            flex-direction: column;
            animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Header 精神圖騰 */
        .header {
            text-align: center;
            margin-bottom: 2.5rem;
        }
        .brand-link {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
            color: var(--text-dark);
            transition: color 0.3s;
        }
        .brand-link:hover { color: var(--accent-blue); }
        .logo-svg {
            width: 42px; height: 42px;
            fill: var(--accent-blue);
        }
        .brand-name {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.04em;
        }
        .spirit-tags {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            margin-top: 1.2rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            letter-spacing: 0.4em;
            font-weight: 700;
            padding-left: 0.4em;
        }
        .spirit-tags .dot {
            color: var(--accent-blue);
            font-size: 1.2rem;
            line-height: 0;
        }
        .pulse-1 { animation: serverPulse 3s infinite ease-in-out; }
        .pulse-2 { animation: serverPulse 3s infinite ease-in-out; animation-delay: 1.5s; }

        /* 系統日誌導言 (TWProbe OS Directive) */
        .terminal-directive {
            max-width: 650px;
            margin: 0 auto 4rem;
            text-align: center;
            font-family: var(--font-mono);
            font-size: 0.75rem;
            line-height: 1.7;
            color: var(--text-muted);
            opacity: 0;
            animation: fadeUp 0.6s 0.1s forwards;
        }
        .terminal-directive::before {
            content: "[TWPROBE_OS: KERNEL INITIALIZED]";
            display: block;
            color: var(--accent-blue);
            margin-bottom: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.05em;
        }

        /* 核心資料庫 (The TWProbe Vault) */
        .pillar-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-bottom: 5rem;
        }
        .pillar-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 1);
            border-radius: 14px;
            padding: 1.8rem 1.5rem;
            box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.03), inset 0 0 0 1px rgba(255,255,255,0.5);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            opacity: 0;
            display: flex;
            flex-direction: column;
        }
        .pillar-card:nth-child(1) { animation: fadeUp 0.6s 0.15s forwards; }
        .pillar-card:nth-child(2) { animation: fadeUp 0.6s 0.25s forwards; }
        .pillar-card:nth-child(3) { animation: fadeUp 0.6s 0.35s forwards; }
        
        .pillar-card:hover {
            transform: translateY(-6px);
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 12px 30px -5px rgba(0, 0, 0, 0.08), inset 0 0 0 1px rgba(255,255,255,1);
        }
        .pillar-header {
            text-align: center;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 1.2rem;
            margin-bottom: 1.5rem;
        }
        .pillar-title-link {
            text-decoration: none;
            color: var(--text-dark);
            display: inline-block;
            transition: color 0.3s ease;
        }
        .pillar-title-link:hover { color: var(--accent-blue); }
        .pillar-title {
            font-size: 1.15rem;
            font-weight: 800;
            margin: 0 0 0.6rem 0;
            letter-spacing: 0.05em;
        }
        .pillar-desc {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            color: var(--text-muted);
            margin: 0;
            font-weight: 500;
            line-height: 1.6;
            letter-spacing: 0.02em;
        }
        .topic-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.5rem;
            margin-top: auto;
        }
        .topic-link {
            background: transparent;
            color: var(--text-dark);
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.6rem 1rem;
            border-radius: 6px;
            text-align: left;
            transition: all 0.25s ease;
            border-left: 2px solid transparent;
            display: flex;
            align-items: center;
        }
        .topic-link::before {
            content: "▸";
            color: var(--text-light);
            margin-right: 0.6rem;
            font-size: 0.9rem;
            transition: color 0.25s;
        }
        .topic-link:hover {
            background: var(--accent-bg);
            color: var(--accent-blue);
            border-left: 2px solid var(--accent-blue);
        }
        .topic-link:hover::before {
            color: var(--accent-blue);
        }

        /* 底層決策矩陣 (Protocol FAQ Section) */
        .protocol-section {
            max-width: 750px;
            margin: 0 auto 4rem;
            border-top: 1px solid var(--border-light);
            padding-top: 4rem;
            opacity: 0;
            animation: fadeUp 0.8s 0.4s forwards;
        }
        .protocol-header {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            color: var(--text-light);
            letter-spacing: 0.2em;
            text-align: center;
            margin-bottom: 3.5rem;
            text-transform: uppercase;
        }
        .protocol-item {
            margin-bottom: 2.5rem;
            padding-bottom: 2.5rem;
            border-bottom: 1px dashed rgba(226, 232, 240, 0.6);
        }
        .protocol-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        .protocol-meta {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            color: var(--accent-blue);
            letter-spacing: 0.15em;
            margin-bottom: 1rem;
            font-weight: 600;
        }
        .protocol-q {
            font-size: 1.05rem;
            font-weight: 800;
            color: var(--text-dark);
            margin: 0 0 1.2rem 0;
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            line-height: 1.5;
        }
        .protocol-q::before {
            content: ">_";
            color: var(--text-light);
            font-family: var(--font-mono);
            font-weight: 500;
            margin-top: 0.1rem;
        }
        .protocol-a {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin: 0;
            line-height: 1.8;
            padding-left: 1.8rem;
            border-left: 2px solid rgba(43, 108, 176, 0.2);
            font-weight: 500;
        }

        /* 游擊隊暗號 (The Manifesto) */
        .manifesto-section {
            margin-top: auto;
            padding-top: 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            opacity: 0;
            animation: fadeUp 0.8s 0.6s forwards;
        }
        .divider {
            width: 40px;
            height: 2px;
            background: var(--text-light);
            border-radius: 2px;
            margin-bottom: 2.5rem;
            opacity: 0.3;
        }
        .manifesto-text {
            font-size: 0.85rem;
            font-weight: 800;
            color: var(--text-muted);
            letter-spacing: 0.25em;
            margin: 0 0 0.8rem 0;
            padding-left: 0.25em;
        }
        .manifesto-eng {
            font-size: 0.65rem;
            font-weight: 600;
            color: var(--text-light);
            letter-spacing: 0.1em;
            margin: 0;
            font-family: var(--font-mono);
        }

        /* RWD: iPad 直立模式強制收束 */
        @media (max-width: 860px) {
            .pillar-grid {
                grid-template-columns: 1fr;
                max-width: 450px;
                margin-left: auto;
                margin-right: auto;
            }
        }
        @media (max-width: 480px) {
            .container { padding: 3rem 1.2rem 2rem; }
            .brand-name { font-size: 1.8rem; }
            .terminal-directive { font-size: 0.7rem; text-align: left; }
            .protocol-q { font-size: 0.95rem; }
            .manifesto-text { font-size: 0.75rem; }
            .manifesto-eng { font-size: 0.55rem; }
        }
    </style>
</head>
<body>

    <div class="container">
        <header class="header">
            <a href={mainSiteUrl} class="brand-link">
                <svg class="logo-svg" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
                <span class="brand-name">{brandName}</span>
            </a>
            <div class="spirit-tags">
                <span>數據</span><span class="dot pulse-1">·</span><span>結構</span><span class="dot pulse-2">·</span><span>真理</span>
            </div>
        </header>

        <div class="terminal-directive">
            致力於抹除社會階層的資訊不對稱。拒絕情緒止痛藥與低效勤奮，嚴格執行決策權物理隔離。本系統專注於提供台灣房地產之底層數據穿透、空間物理邊界檢驗，與防禦性資產佈局之高維度戰術。
        </div>

        <main class="pillar-grid">
            {pillars.map(p => (
                <div class="pillar-card">
                    <div class="pillar-header">
                        <a href={`${mainSiteUrl}/${p.slug}/`} class="pillar-title-link">
                            <h2 class="pillar-title">{p.title}</h2>
                        </a>
                        <p class="pillar-desc">{p.desc}</p>
                    </div>
                    <div class="topic-grid">
                        {p.topics.map(t => (
                            <a href={`${mainSiteUrl}/${p.slug}/`} class="topic-link">{t}</a>
                        ))}
                    </div>
                </div>
            ))}
        </main>

        <section class="protocol-section">
            <div class="protocol-header">TWPROBE CORE PROTOCOL // 底層決策矩陣</div>
            {protocols.map(protocol => (
                <div class="protocol-item">
                    <div class="protocol-meta">{protocol.meta}</div>
                    <h3 class="protocol-q">{protocol.q}</h3>
                    <p class="protocol-a">{protocol.a}</p>
                </div>
            ))}
        </section>

        <section class="manifesto-section">
            <div class="divider"></div>
            <p class="manifesto-text">信號散佈於平原，真理封存於此。</p>
            <p class="manifesto-eng">Signals are scattered across the plains. Truth is sealed here.</p>
        </section>
    </div>

</body>
</html>
