---
// ==============================================
// TWProbe Hub - NEXUS Terminal Edition (V3.0)
// Architecture: 0 External Requests / Pure Tailwind CSS
// ==============================================

const brandName = "TWProbe";
const mainSiteUrl = "https://twprobe.com";
const hubUrl = "https://hub.twprobe.com/";

// 靜態資源路徑 (確保位於 public/ 資料夾)
const ogImage = `${hubUrl}og-social-preview.jpg`;
const logoPng = `${hubUrl}logo.png`;
const faviconPng = `${hubUrl}favicon.png`;

// 核心資料庫 (The Vault - 80% 權重)
const pillars = [
  {
    title: "交易與持有",
    slug: "real-estate-holding",
    desc: "交易流程與資產管理",
    topics: ["購屋流程", "房產銷售", "驗屋重點", "租賃指南", "室內裝修", "管理維護"]
  },
  {
    title: "開發與工程",
    slug: "development-engineering",
    desc: "土地價值與營造細節",
    topics: ["土地開發", "營造工程", "建商評估", "建案分析", "建築設計", "都更危老"]
  },
  {
    title: "投資與法規",
    slug: "investment-regulation",
    desc: "稅務法規與市場趨勢",
    topics: ["市場趨勢", "區域發展", "房貸理財", "法規稅務", "投資策略", "商用房產"]
  },
];

// 精銳分發陣列 (The Elite Trinity - 20% 權重)
const trinity = [
  { 
    id: "signal", 
    code: "SIGNAL", 
    name: "X (Twitter)", 
    url: "https://x.com/probe54670", 
    hoverEffect: "group-hover:text-white group-hover:drop-shadow-[0_0_15px_rgba(255,255,255,0.6)]" 
  },
  { 
    id: "gravity", 
    code: "GRAVITY", 
    name: "Reddit", 
    url: "https://www.reddit.com/r/TWProbe/", 
    hoverEffect: "group-hover:text-[#FF4500] group-hover:drop-shadow-[0_0_15px_rgba(255,69,0,0.6)]" 
  },
  { 
    id: "prism", 
    code: "PRISM", 
    name: "Pinterest", 
    url: "https://www.pinterest.com/infotwprobe/", 
    hoverEffect: "group-hover:text-[#E60023] group-hover:drop-shadow-[0_0_15px_rgba(230,0,35,0.6)]" 
  }
];

const footerLinks = [
    { name: "關於本站", u: "https://twprobe.com/about-twprobe/" },
    { name: "網站地圖", u: "https://twprobe.com/sitemap/" },
    { name: "情報矩陣", u: "https://hub.twprobe.com/" },
    { name: "服務條款", u: "https://twprobe.com/terms-of-service/" },
    { name: "隱私政策", u: "https://twprobe.com/privacy-policy/" },
    { name: "免責聲明", u: "https://twprobe.com/disclaimer/" },
];
---

<html lang="zh-TW" class="bg-black text-slate-300 font-sans antialiased selection:bg-blue-500/30">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>NEXUS Terminal | TWProbe 情報矩陣</title>
    <meta name="description" content="TWProbe 核心情報終端。結構化整合台灣房產交易、開發與投資三大脈絡。">
    <link rel="canonical" href={hubUrl} />
    <link rel="icon" type="image/png" sizes="96x96" href={faviconPng} />
    <link rel="apple-touch-icon" href={faviconPng} />

    <meta property="og:locale" content="zh-TW" />
    <meta property="og:site_name" content="TWProbe" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={hubUrl} />
    <meta property="og:title" content="NEXUS Terminal | TWProbe 核心情報終端" />
    <meta property="og:description" content="結構化整合台灣房產交易、開發與投資三大脈絡。提供中立、客觀的深度分析。" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@probe54670" />

    <style>
        body { margin: 0; padding: 0; min-height: 100vh; display: flex; flex-direction: column; }
    </style>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-black text-slate-300 flex flex-col min-h-screen">
    <div class="fixed top-0 left-1/2 -translate-x-1/2 w-[800px] h-[300px] bg-blue-900/10 blur-[120px] pointer-events-none z-0"></div>

    <div class="relative z-10 w-full max-w-5xl mx-auto px-6 py-16 flex-1 flex flex-col">
        
        <header class="flex flex-col items-center justify-center mb-20 space-y-4">
            <a href={mainSiteUrl} class="flex items-center gap-3 group">
                <svg class="w-10 h-10 text-white group-hover:text-blue-400 transition-colors duration-300" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                </svg>
                <span class="text-3xl font-extrabold text-white tracking-tight">{brandName}</span>
            </a>
            <p class="text-sm text-slate-500 uppercase tracking-[0.2em] font-medium">Intelligence Terminal</p>
        </header>

        <main class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24">
            {pillars.map(p => (
                <div class="group flex flex-col bg-white/[0.03] border border-white/10 rounded-2xl p-6 backdrop-blur-md hover:bg-white/[0.06] hover:border-white/20 hover:-translate-y-1 transition-all duration-300 ease-out shadow-lg hover:shadow-2xl hover:shadow-blue-900/20">
                    <div class="mb-6 border-b border-white/10 pb-4">
                        <h2 class="text-xl font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">{p.title}</h2>
                        <p class="text-xs text-slate-400 font-medium tracking-wide">{p.desc}</p>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mt-auto">
                        {p.topics.map(t => (
                            <a href={`${mainSiteUrl}/${p.slug}/`} class="flex items-center justify-center py-2.5 px-2 bg-black/40 border border-white/5 rounded-lg text-sm text-slate-300 font-medium hover:bg-blue-600 hover:text-white hover:border-blue-500 transition-all duration-200">
                                {t}
                            </a>
                        ))}
                    </div>
                </div>
            ))}
        </main>

        <section class="mt-auto mb-16 flex flex-col items-center">
            <div class="text-[10px] text-slate-600 uppercase tracking-[0.3em] font-bold mb-8">The Elite Trinity</div>
            <div class="flex flex-wrap justify-center gap-12 md:gap-24">
                {trinity.map(t => (
                    <a href={t.url} target="_blank" rel="me noopener noreferrer" class="group flex flex-col items-center gap-4 outline-none">
                        <div class={`text-slate-500 transition-all duration-500 ${t.hoverEffect}`}>
                            <svg class="w-10 h-10 fill-currentColor" viewBox="0 0 24 24">
                                {t.id === 'signal' && <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>}
                                {t.id === 'gravity' && <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.196-.491.96 0 1.741.782 1.741 1.74 0 .96-.78 1.74-1.74 1.74-.961 0-1.74-.78-1.74-1.74 0-.175.029-.344.081-.502-1.353-.984-3.238-1.574-5.32-1.637l1.037-4.88 3.486.732c.046.002.091.004.13.004zM5.27 12.19c0-.959.78-1.741 1.74-1.741.96 0 1.74.782 1.74 1.74 0 .96-.78 1.74-1.74 1.74-.96 0-1.74-.78-1.74-1.74zm11.39 6.848c-1.355 1.355-4.437 1.355-5.792 0-1.355-1.355.087-2.797 1.442-4.152 1.355-1.355 4.437-1.355 5.792 0 1.355 1.355-.087 2.797-1.442 4.152zm-1.69-5.108c-.96 0-1.74-.78-1.74-1.74 0-.96.78-1.741 1.74-1.741.96 0 1.74.781 1.74 1.74 0 .96-.78 1.74-1.74 1.74z"/>}
                                {t.id === 'prism' && <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.399.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.951-7.252 4.173 0 7.41 2.967 7.41 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.367 18.62 0 12.017 0z"/>}
                            </svg>
                        </div>
                        <div class="flex flex-col items-center">
                            <span class="text-xs font-bold tracking-widest text-slate-400 group-hover:text-white transition-colors duration-300">{t.code}</span>
                            <span class="text-[10px] text-slate-600 mt-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300">{t.name}</span>
                        </div>
                    </a>
                ))}
            </div>
        </section>

    </div>

    <footer class="relative z-10 border-t border-white/5 py-8 mt-auto">
        <div class="max-w-5xl mx-auto px-6">
            <nav class="flex flex-wrap justify-center gap-x-8 gap-y-4 mb-6">
                {footerLinks.map(f => (
                    <a href={f.u} class="text-xs font-medium text-slate-500 hover:text-white transition-colors duration-200">{f.name}</a>
                ))}
            </nav>
            <p class="text-center text-[10px] text-slate-700 font-medium">
                © 2026 {brandName}. ALL RIGHTS RESERVED.
            </p>
        </div>
    </footer>

</body>
</html>
