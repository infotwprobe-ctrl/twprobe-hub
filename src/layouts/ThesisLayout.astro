---
// ==============================================
// TWProbe Hub - Thesis Layout (V6.0 + Deep SEO)
// Target: Academic Typography / Crawler Trapping / JSON-LD
// ==============================================

import ThemeToggle from '../components/ThemeToggle.astro';
import TwprobeButtons from '../components/TwprobeButtons.astro';
import { ClientRouter } from 'astro:transitions';
const { frontmatter, headings } = Astro.props;

// 1. 抓取所有文章並進行「拓撲邏輯排序」
const allPosts = await Astro.glob("../pages/**/*.md");

const sortedPosts = allPosts.sort((a, b) => {
    const idA = a.frontmatter.docId || "";
    const idB = b.frontmatter.docId || "";
    const getNum = (id) => {
        if (id.startsWith("PILLAR")) return parseFloat(id.split("-")[1]);
        if (id.startsWith("PROTOCOL")) return parseFloat(id.split("-")[1]);
        return 999;
    };
    return getNum(idA) - getNum(idB);
});

// 2. 算力分配：定位當前文章，並推算上一篇與下一篇
const currentIndex = sortedPosts.findIndex(
    (post) => post.url === Astro.url.pathname,
);
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const nextPost =
    currentIndex < sortedPosts.length - 1
        ? sortedPosts[currentIndex + 1]
        : null;

// 3. 爬蟲誘捕矩陣：語義化擴充閱讀 (同屬性優先)
const relatedPosts = sortedPosts
    .filter((p) => p.url !== Astro.url.pathname)
    .map(p => {
        let score = 0;
        const pId = p.frontmatter.docId || "";
        const cId = frontmatter.docId || "";
        if (pId.split('-')[0] === cId.split('-')[0]) score += 1;
        const getPillarNum = (id) => id.split('-')[1]?.split('.')[0] || "X";
        if (getPillarNum(pId) === getPillarNum(cId)) score += 5;
        score += Math.random();
        return { post: p, score };
    })
    .sort((a, b) => b.score - a.score)
    .map(x => x.post)
    .slice(0, 3);

const canonicalURL = new URL(
    Astro.url.pathname,
    Astro.site || "https://hub.twprobe.com"
);
const ogImagePath = `/og${Astro.url.pathname.replace(/\/$/, "")}.png`;
const ogImage = frontmatter.image 
    ? new URL(frontmatter.image, canonicalURL).toString()
    : new URL(ogImagePath, canonicalURL).toString();

const pageTitle = `${frontmatter.title} | TWProbe`;
const pageDescription = frontmatter.abstract;
---

<html lang="zh-TW" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <link rel="icon" type="image/png" href="/favicon.png" sizes="any" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <ClientRouter />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="article" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:image" content={ogImage} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={pageTitle} />
        <meta property="twitter:description" content={pageDescription} />
        <meta property="twitter:image" content={ogImage} />

        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@graph": [
                    {
                        "@type": "BreadcrumbList",
                        itemListElement: [
                            {
                                "@type": "ListItem",
                                position: 1,
                                name: "KERNEL",
                                item: "https://hub.twprobe.com",
                            },
                            {
                                "@type": "ListItem",
                                position: 2,
                                name: frontmatter.docId,
                                item: canonicalURL.toString(),
                            },
                        ],
                    },
                    {
                        "@type": "Article",
                        headline: frontmatter.title,
                        description: frontmatter.abstract,
                        image: [ogImage],
                        datePublished: frontmatter.date || new Date().toISOString().split('T')[0],
                        dateModified: frontmatter.updatedDate || frontmatter.date || new Date().toISOString().split('T')[0],
                        author: { 
                            "@type": "Organization", 
                            "name": "TWProbe",
                            "url": "https://twprobe.com" 
                        },
                        publisher: { 
                            "@type": "Organization", 
                            "name": "TWProbe",
                            "logo": {
                                "@type": "ImageObject",
                                "url": new URL("/favicon.png", canonicalURL).toString()
                            }
                        },
                        mainEntityOfPage: {
                            "@type": "WebPage",
                            "@id": canonicalURL.toString(),
                        },
                        inLanguage: "zh-TW",
                        keywords: `${frontmatter.docId}, TWProbe, 宏觀週期, 資本防禦`,
                    },
                ],
            })}
        />
        <script is:inline>
            // Prevention of Flash of Unstyled Content (FOUC)
            if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        </script>
    </head>
    <body
        class="bg-paper dark:bg-slate-950 text-slate-800 dark:text-slate-300 font-sans min-h-screen flex flex-col selection:bg-blue-100 selection:text-blue-900 dark:selection:text-blue-200 transition-colors duration-300 relative overflow-x-hidden antialiased"
    >
        <!-- Background Matrix Grid -->
        <div class="fixed inset-0 z-[-1] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.03] dark:opacity-[0.05] mix-blend-overlay"></div>

        <!-- 閱讀進度條 -->
        <div class="fixed top-0 left-0 w-full h-1 bg-transparent z-[60]">
            <div id="reading-progress" class="h-full bg-blue-600 dark:bg-twprobe-blue w-0 transition-all duration-150 ease-out"></div>
        </div>
        
        <TwprobeButtons />
        <nav
            class="sticky top-0 z-50 border-b border-slate-200 dark:border-slate-800/80 bg-white/90 dark:bg-slate-950/80 backdrop-blur-md px-6 py-4 flex flex-col md:flex-row justify-between items-center gap-4 shadow-sm"
        >
            <div class="flex items-center gap-6">
                <a href="/" class="flex items-center gap-3 group no-underline">
                    <svg class="h-7 w-7 rounded-md shadow-sm transition-transform group-hover:scale-105" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
                        <rect width="32" height="32" fill="#f8fafc" rx="4" class="dark:fill-slate-800" />
                        <g transform="translate(4, 4)">
                            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="#2563EB" class="dark:fill-twprobe-blue" />
                        </g>
                    </svg>
                    <span class="font-bold text-slate-800 dark:text-slate-100 text-[1.05rem] tracking-wide">
                        TWProbe 深層架構中樞
                    </span>
                </a>
                <div class="hidden md:flex items-center gap-6 text-sm font-bold text-slate-500 dark:text-slate-400">
                    <a href="/" class="hover:text-blue-600 dark:hover:text-twprobe-blue transition-colors no-underline">大廳</a>
                    <a href="/category/交易持有" class="hover:text-blue-600 dark:hover:text-twprobe-blue transition-colors no-underline">交易持有</a>
                    <a href="/category/開發工程" class="hover:text-blue-600 dark:hover:text-twprobe-blue transition-colors no-underline">開發工程</a>
                    <a href="/category/投資法規" class="hover:text-blue-600 dark:hover:text-twprobe-blue transition-colors no-underline">投資法規</a>
                </div>
            </div>
        </nav>

        <div class="flex-grow w-full max-w-[1200px] mx-auto px-6 py-16 flex flex-col lg:flex-row gap-12 items-start relative">
            <main class="w-full max-w-3xl flex-grow mx-auto lg:mx-0">
            <article
                class="prose prose-slate dark:prose-invert prose-lg max-w-[72ch] prose-headings:font-extrabold prose-a:text-blue-600 dark:prose-a:text-blue-400 mx-auto"
            >
                <span
                    class="font-mono text-sm font-bold text-blue-600 dark:text-twprobe-blue tracking-widest block mb-2"
                >
                    {frontmatter.docId}
                </span>
                <h1 class="text-[clamp(1.8rem,5vw,3rem)] font-extrabold tracking-tight mb-8 dark:text-slate-100 leading-tight">
                    {frontmatter.title}
                </h1>

                <slot />
            </article>

            <!-- 深度導流 CTA (Call To Action) 極致升級 -->
            <div class="my-20 bg-gradient-to-br from-slate-800 to-slate-900 dark:from-slate-900 dark:to-black rounded-2xl p-10 md:p-12 text-white shadow-2xl dark:shadow-[0_0_40px_rgba(37,99,235,0.1)] dark:ring-1 dark:ring-slate-800 flex flex-col md:flex-row items-center justify-between gap-8 overflow-hidden relative group">
                <div class="absolute -inset-x-0 -inset-y-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 mix-blend-overlay group-hover:scale-105 transition-transform duration-700"></div>
                <div class="absolute w-64 h-64 bg-twprobe-blue/20 rounded-full blur-3xl -top-10 -right-10 pointer-events-none group-hover:bg-twprobe-blue/30 transition-colors duration-500"></div>

                <div class="relative z-10 flex-grow">
                    <span class="font-mono text-xs md:text-sm text-blue-400 dark:text-twprobe-blue font-bold tracking-widest uppercase mb-4 flex items-center gap-3">
                        <span class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.8)] animate-pulse"></span>
                        TWPROBE MASTER SUBSYSTEM
                    </span>
                    <h3 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4 text-white">想要解鎖本體智庫的所有模塊？</h3>
                    <p class="text-slate-300 dark:text-slate-400 leading-relaxed text-lg max-w-2xl">
                        此處僅為公開情報的邊緣讀取節點。造訪 TWProbe 官方主站，取得深度資本防禦矩陣與宏觀週期研報。
                    </p>
                </div>
                <div class="relative z-10 whitespace-nowrap w-full md:w-auto mt-4 md:mt-0">
                    <a href="https://twprobe.com" class="group flex items-center justify-center gap-3 bg-blue-600 hover:bg-blue-500 dark:bg-twprobe-blue dark:hover:bg-blue-500 text-white px-8 md:px-10 py-4 md:py-5 rounded-xl font-bold text-lg transition-all shadow-[0_0_20px_rgba(37,99,235,0.4)] hover:shadow-[0_0_30px_rgba(37,99,235,0.6)] no-underline w-full md:w-auto">
                        <span>啟動連接程序</span>
                        <svg class="w-6 h-6 group-hover:translate-x-1.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </a>
                </div>
            </div>

            <hr class="my-16 border-slate-200 dark:border-slate-800/80" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {
                    prevPost ? (
                        <a
                            href={prevPost.url}
                            class="group p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl hover:border-blue-400 dark:hover:border-slate-600 hover:shadow-md dark:shadow-none transition-all flex flex-col text-left no-underline"
                        >
                            <span class="text-xs font-mono text-slate-400 dark:text-slate-500 tracking-widest mb-2 group-hover:text-blue-600 dark:group-hover:text-twprobe-blue">
                                ← PREVIOUS
                            </span>
                            <span class="font-bold text-slate-800 dark:text-slate-200 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                                {prevPost.frontmatter.title}
                            </span>
                        </a>
                    ) : (
                        <div />
                    )
                }

                {
                    nextPost && (
                        <a
                            href={nextPost.url}
                            class="group p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl hover:border-blue-400 dark:hover:border-slate-600 hover:shadow-md dark:shadow-none transition-all flex flex-col text-right no-underline"
                        >
                            <span class="text-xs font-mono text-slate-400 dark:text-slate-500 tracking-widest mb-2 group-hover:text-blue-600 dark:group-hover:text-twprobe-blue">
                                NEXT →
                            </span>
                            <span class="font-bold text-slate-800 dark:text-slate-200 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                                {nextPost.frontmatter.title}
                            </span>
                        </a>
                    )
                }
            </div>

            <div class="mt-12 pt-12 border-t border-slate-200 dark:border-slate-800/80">
                <div
                    class="font-mono text-xs font-bold tracking-widest text-slate-400 dark:text-slate-500 mb-6 uppercase flex items-center"
                >
                    <span class="w-2 h-2 bg-blue-600 dark:bg-twprobe-blue mr-3 block"></span>
                    Topological Extension / 矩陣延伸解析
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    {
                        relatedPosts.map((related) => (
                            <a
                                href={related.url}
                                class="block p-5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg hover:border-blue-400 dark:hover:border-slate-600 hover:shadow-md dark:shadow-none transition-all no-underline group"
                            >
                                <span class="font-mono text-[10px] text-slate-400 dark:text-slate-500 block mb-2 font-bold tracking-widest">
                                    {related.frontmatter.docId}
                                </span>
                                <h4 class="font-bold text-slate-800 dark:text-slate-200 text-sm leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                                    {related.frontmatter.title}
                                </h4>
                            </a>
                        ))
                    }
                </div>
            </div>
            </main>

            {headings && headings.length > 0 && (
                <aside class="hidden lg:block w-64 flex-shrink-0 sticky top-32">
                    <div class="font-mono text-xs font-bold text-slate-400 dark:text-slate-500 tracking-widest mb-6 uppercase flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-twprobe-blue rounded-full"></div>
                        Table of Contents
                    </div>
                    <ul class="space-y-3.5 text-sm border-l-2 border-slate-100 dark:border-slate-800 pl-4 py-1">
                        {headings.map((h) => (
                            <li>
                                <a 
                                    href={`#${h.slug}`} 
                                    class={`toc-link block text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors line-clamp-2 ${h.depth > 2 ? 'ml-3 text-[13px]' : 'font-medium'}`}
                                    data-slug={h.slug}
                                >
                                    {h.text}
                                </a>
                            </li>
                        ))}
                    </ul>
                </aside>
            )}
        </div>

        <footer
            class="border-t border-slate-200 dark:border-slate-800/80 bg-white dark:bg-slate-950 py-12 mt-12 text-center transition-colors duration-300"
        >
            <span class="font-mono text-xs text-slate-400 dark:text-slate-500 tracking-widest">
                &copy; 2024 - 2026 <a href="https://twprobe.com" class="font-bold hover:text-blue-500 dark:hover:text-blue-400 transition-colors no-underline">TWProbe</a>. All rights reserved.
            </span>
        </footer>

        <TwprobeButtons />

        <script>
            document.addEventListener('astro:page-load', () => {
                // Reading Progress Bar
            const updateProgress = () => {
                const article = document.querySelector('article');
                const progressBar = document.getElementById('reading-progress');
                if (article && progressBar) {
                    const articleTop = article.offsetTop;
                    const articleHeight = article.offsetHeight;
                    const windowHeight = window.innerHeight;
                    const scrollY = window.scrollY;

                    let progress = 0;
                    if (scrollY > articleTop) {
                        progress = ((scrollY - articleTop) / (articleHeight - windowHeight)) * 100;
                    }
                    progressBar.style.width = `${Math.min(Math.max(progress, 0), 100)}%`;
                }
            };
            window.addEventListener('scroll', updateProgress, {passive: true});
            window.addEventListener('resize', updateProgress, {passive: true});
            updateProgress();

            // Scrollspy for TOC
            const observerOptions = {
                root: null,
                rootMargin: '-20% 0px -60% 0px',
                threshold: 0
            };
            
            const headingElements = Array.from(document.querySelectorAll('article h1, article h2, article h3, article h4, article h5, article h6'))
                                        .filter(el => el.id);
            
            // Highlight the first item by default if no scroll
            if (headingElements.length > 0) {
               const links = document.querySelectorAll('.toc-link');
               if (links.length > 0 && window.scrollY < 50) {
                   links[0].classList.add('text-blue-600', 'font-black', 'dark:text-twprobe-blue');
                   links[0].classList.remove('text-slate-500', 'dark:text-slate-400');
               }
            }

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const id = entry.target.id;
                        document.querySelectorAll('.toc-link').forEach(link => {
                            if (link.getAttribute('data-slug') === id) {
                                link.classList.add('text-blue-600', 'font-black', 'dark:text-twprobe-blue');
                                link.classList.remove('text-slate-500', 'dark:text-slate-400', 'font-medium');
                            } else {
                                link.classList.remove('text-blue-600', 'font-black', 'dark:text-twprobe-blue');
                                link.classList.add('text-slate-500', 'dark:text-slate-400', 'font-medium');
                            }
                        });
                    }
                });
            }, observerOptions);

            headingElements.forEach(el => observer.observe(el));
            });
        </script>
    </body>
</html>
